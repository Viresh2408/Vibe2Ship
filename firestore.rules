rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── tasks ────────────────────────────────────────────────────────────────
    // Users can only read/write their own tasks.
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null
                                   && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid;
    }

    // ─── users ────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    // ─── fcm_tokens ───────────────────────────────────────────────────────────
    // Users can only read/write their own FCM token document.
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    // ─── _rate_limits ─────────────────────────────────────────────────────────
    // Rate limit documents are written by the server (Firebase Admin SDK) only.
    // Clients must never be able to read or write them directly.
    // Firebase Admin SDK bypasses these rules — writes from API routes are fine.
    match /_rate_limits/{docId} {
      allow read, write: if false; // server-only via Admin SDK
    }

    // Default: deny everything not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
