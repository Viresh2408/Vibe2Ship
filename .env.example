# ============================================================
# The Last-Minute Life Saver — Environment Variables
# Copy this file to .env.local and populate all values
# NEVER commit .env.local to version control
# ============================================================

# ─── Google AI Studio / Gemini ───────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_api_key_here
# Configurable model name (defaults to gemini-1.5-flash if unset)
GEMINI_MODEL=gemini-2.5-flash

# ─── Google Cloud / Vertex AI ────────────────────────────────
# GCP project ID — find at console.cloud.google.com
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to service account JSON (local dev only — Cloud Run uses ADC)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Firebase Client SDK (public — safe to expose) ──────────
# Get from: Firebase Console → Project Settings → General → Your apps → Web
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_fcm_vapid_key_for_web_push

# ─── Firebase Admin SDK (server-side only — never expose) ────
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── App Configuration ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Rate Limiting ────────────────────────────────────────────
# /api/panic: max requests per window (per user)
PANIC_RATE_LIMIT_MAX=10
# /api/panic: window duration in milliseconds (60000 = 1 minute)
PANIC_RATE_LIMIT_WINDOW_MS=60000
